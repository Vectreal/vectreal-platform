{
	"name": "terraform",
	"$schema": "../node_modules/nx/schemas/project-schema.json",
	"root": "terraform",
	"sourceRoot": "terraform",
	"projectType": "application",
	"tags": ["scope:infra"],
	"targets": {
		"plan-infrastructure": {
			"executor": "nx:run-commands",
			"options": {
				"command": "terraform -chdir=terraform init -input=false && terraform -chdir=terraform validate && terraform -chdir=terraform plan"
			}
		},
		"apply-infrastructure-auto-approve": {
			"executor": "nx:run-commands",
			"options": {
				"command": "terraform -chdir=terraform init -input=false && terraform -chdir=terraform validate && terraform -chdir=terraform apply -auto-approve"
			}
		},
		"apply-infrastructure": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/apply-infrastructure.sh"
			}
		},
		"setup-fly-secrets-staging": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/setup-fly-secrets.sh --env staging"
			}
		},
		"setup-fly-secrets-prod": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/setup-fly-secrets.sh --env prod"
			}
		},
		"verify-fly-secrets": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/setup-fly-secrets.sh --verify"
			}
		},
		"setup-modal-secrets": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/setup-modal-secrets.sh"
			}
		}
	}
}