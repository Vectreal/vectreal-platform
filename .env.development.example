# =============================================================================
# VECTREAL PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy to .env.development and fill in your values.
# NEVER commit .env.development to version control.
#
# Sections:
#   1. Local development  - used only by the local dev server + `supabase start`
#   2. OAuth providers    - shared across all environments
#   3. Shared deployment  - single values pushed to all deployed environments
#   4. Staging            - secrets specific to the staging Fly.io app
#   5. Production         - secrets specific to the production Fly.io app

# =============================================================================
# 1. LOCAL DEVELOPMENT
# =============================================================================
# These values are consumed by the local Vite dev server and the local
# Supabase instance (`pnpm supabase start`). They are never deployed.

NODE_ENV=development
COMPOSE_PROJECT_NAME=vectreal-platform

# Dev server
VITE_DEV_PORT=4200
PROD_PORT=3001
VECTREAL_URL=http://localhost:${VITE_DEV_PORT}

# Local Supabase ports (supabase start)
SUPABASE_API_PORT=54321
SUPABASE_DB_PORT=54322
SUPABASE_STUDIO_PORT=54323
SUPABASE_INBUCKET_PORT=54324
SUPABASE_ANALYTICS_PORT=54327

# Local Supabase credentials
# The JWT secret is only needed if you change it from the default dev value.
SUPABASE_DB_PASSWORD=postgres
# SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Generated by `supabase start` - copy from its output
SUPABASE_URL=http://localhost:${SUPABASE_API_PORT}
SUPABASE_KEY=
SUPABASE_SECRET_KEY=

# Local database
DATABASE_URL=postgresql://postgres:${SUPABASE_DB_PASSWORD}@localhost:${SUPABASE_DB_PORT}/postgres
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=20
DB_MAX_LIFETIME=1800

# Local email delivery (optional)
# In local dev, Supabase captures outbound emails via Inbucket (port 54324).
# Set these only if you want to test actual Resend delivery locally.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Local hook secret - must match what `supabase start` uses in config.toml.
# Generate: openssl rand -base64 32 | tr -d '\n' | xargs -I{} echo "v1,whsec_{}"
SEND_EMAIL_HOOK_SECRET=

# Local contact form PII encryption (optional - uses CSRF fallback if unset)
CONTACT_DATA_ENCRYPTION_KEY=

# Vite dev tooling
VITE_DEV_TOOLS=true
VITE_MOCK_API=false
VITE_DEBUG_MODE=true
VITE_HMR_PORT=${VITE_DEV_PORT}
VITE_HMR_HOST=localhost
VITE_PUBLIC_POSTHOG_ENABLED=false

# VITE_PUBLIC_ASSET_BASE_URL is intentionally absent here.
# In CI it is set to the R2 CDN origin (e.g. https://static.vectreal.com) via
# Docker build-arg so built asset URLs point to the edge. Locally Vite defaults
# to '/' and serves assets from the dev server directly.

# In local dev these can be left empty - verification is skipped automatically.
# But they can be set to test the full bot protection flow with Cloudflare Turnstile test keys.
CLOUDFLARE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CLOUDFLARE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# =============================================================================
# IMAGE-TO-3D GENERATION RUNTIME
# =============================================================================
# Two modes — pick one:
#
# MOCK (default for local dev): platform fakes the full job lifecycle internally,
#   no runtime process or network call needed.
#
# LIVE: disable mock and point at the Modal runtime URL.
#   To get a URL: pip install modal && modal setup && pnpm nx run img-to-3d-runtime:modal-serve
#   Modal prints a URL; copy it below. The GPU function runs in Modal cloud.
#   For production, use the deployed URL from: pnpm nx run img-to-3d-runtime:modal-deploy

IMG_TO_3D_MOCK_MODE=true
IMG_TO_3D_RUNTIME_BASE_URL=
IMG_TO_3D_RUNTIME_AUTH_SECRET=

# Optional tuning:
# IMG_TO_3D_JOB_TOKEN_SECRET=           # falls back to CSRF_SECRET
# IMG_TO_3D_MAX_IMAGE_BYTES=            # default: 10MB
# IMG_TO_3D_RATE_LIMIT_MAX_REQUESTS=3
# IMG_TO_3D_RATE_LIMIT_WINDOW_MS=600000 # 10 minutes

# =============================================================================
# MODAL — IMAGE-TO-3D RUNTIME DEPLOYMENT
# =============================================================================
# Manages the GPU inference service (apps/img-to-3d-runtime/modal_app.py).
#
# One-time setup:
#   pip install modal && modal setup
#   pnpm nx run terraform:setup-modal-secrets   # reads vars below, creates Modal secret
#   pnpm nx run img-to-3d-runtime:modal-deploy
#
# CI secret (GitHub → repository secrets):
#   MODAL_TOKEN_ID / MODAL_TOKEN_SECRET  →  modal token new
#
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Auth secret shared between platform and Modal runtime.
# Generate: openssl rand -base64 32
IMG_TO_3D_RUNTIME_AUTH_SECRET_PROD=

# HuggingFace token — required if the model is gated on HuggingFace.
HF_TOKEN=

# =============================================================================
# 2. OAUTH PROVIDERS
# =============================================================================
# These credentials are registered once per OAuth app. The same set is used
# locally and in deployed environments (Supabase reads them via env() in
# config.toml). Staging and prod typically share the same OAuth app unless
# you maintain separate apps per environment.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# 3. SHARED DEPLOYMENT SECRETS
# =============================================================================
# These have a single value that is identical across staging and production.
# setup-fly-secrets.sh reads FROM_EMAIL and CONTACT_INBOX_EMAIL from here.

# GitHub release automation (Release Please app)
RELEASE_APP_ID=
# Path to PEM relative to repo root (preferred over inline key)
RELEASE_APP_PRIVATE_KEY_FILE=credentials/github-release-app.private-key.pem

# Supabase CLI access token - required for hook sync + remote DB operations.
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Email sender - all outbound emails use this verified address.
FROM_EMAIL="Vectreal <noreply@mail.vectreal.com>"

# Contact form inbox - where contact submissions are forwarded.
CONTACT_INBOX_EMAIL=info@vectreal.com

# PostHog analytics (same project across all environments)
# Set VITE_PUBLIC_POSTHOG_ENABLED=true locally only when testing the consent flow.
VITE_PUBLIC_POSTHOG_TOKEN=phc_your-posthog-project-api-key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# Vectreal preview embeds - baked into the client bundle at Docker build time.
#
# VITE_PUBLIC_VECTREAL_API_KEY_PROD:
#   API token used in newsroom article iframes and the landing page demo fallback.
#   Generate or copy from your Vectreal dashboard → API Keys.
VITE_PUBLIC_VECTREAL_API_KEY_PROD=your-vectreal-api-key
#
# VITE_PUBLIC_DEMO_SCENE_URL:
#   Full fullscreen preview URL for the landing page 3D demo (including ?token=).
#   Format: https://vectreal.com/preview/fullscreen/{orgId}/{sceneId}?token={token}
#   Leave empty to use the built-in fallback demo scene.
#   Camera IDs that must exist in the published scene: hero, detail, side, context
VITE_PUBLIC_DEMO_SCENE_URL=

# =============================================================================
# 4. STAGING ENVIRONMENT
# =============================================================================
# Secrets for the staging Fly.io app (vectreal-platform-staging, fra).
# setup-fly-secrets.sh --env staging reads these and pushes to Fly.io secrets.

SUPABASE_PROJECT_REF_STAGING=
SUPABASE_DB_PASSWORD_STAGING=
DATABASE_URL_STAGING=postgresql://postgres:${SUPABASE_DB_PASSWORD_STAGING}@db.${SUPABASE_PROJECT_REF_STAGING}.supabase.co:5432/postgres
SUPABASE_URL_STAGING=https://${SUPABASE_PROJECT_REF_STAGING}.supabase.co
SUPABASE_KEY_STAGING=eyJhbGc...your-staging-anon-key
SUPABASE_SECRET_KEY_STAGING=eyJhbGc...your-staging-secret-key

APPLICATION_URL_STAGING=https://staging.vectreal.com

# Generate: openssl rand -base64 32
CSRF_SECRET_STAGING=

# Stripe test key for staging
STRIPE_SECRET_KEY_STAGING=sk_test_your-staging-stripe-secret-key

# Supabase send_email hook HMAC secret (format: v1,whsec_<base64>)
# setup-fly-secrets.sh syncs this to both Fly.io and the Supabase project hook config.
# Generate: openssl rand -base64 32 | tr -d '\n' | xargs -I{} echo "v1,whsec_{}"
SEND_EMAIL_HOOK_SECRET_STAGING=

# Resend email delivery
RESEND_API_KEY_STAGING=
# Resend webhook secret for /api/contact/webhook signature verification
RESEND_WEBHOOK_SECRET_STAGING=

# PII encryption key for contact form submissions (32-byte base64)
# Generate: openssl rand -base64 32
CONTACT_DATA_ENCRYPTION_KEY_STAGING=

# Cloudflare Turnstile (staging site key from dash.cloudflare.com > Turnstile)
CLOUDFLARE_TURNSTILE_SITE_KEY_STAGING=
CLOUDFLARE_TURNSTILE_SECRET_KEY_STAGING=

# =============================================================================
# 5. PRODUCTION ENVIRONMENT
# =============================================================================
# Secrets for the production Fly.io app (vectreal-platform, fra).
# setup-fly-secrets.sh --env prod reads these and pushes to Fly.io secrets.

SUPABASE_PROJECT_REF_PROD=
SUPABASE_DB_PASSWORD_PROD=
DATABASE_URL_PROD=postgresql://postgres:${SUPABASE_DB_PASSWORD_PROD}@db.${SUPABASE_PROJECT_REF_PROD}.supabase.co:5432/postgres
SUPABASE_URL_PROD=https://${SUPABASE_PROJECT_REF_PROD}.supabase.co
SUPABASE_KEY_PROD=eyJhbGc...your-production-anon-key
SUPABASE_SECRET_KEY_PROD=eyJhbGc...your-production-secret-key

APPLICATION_URL_PROD=https://vectreal.com

# Generate: openssl rand -base64 32
CSRF_SECRET_PROD=

# Use the live Stripe key for production
STRIPE_SECRET_KEY_PROD=sk_live_your-production-stripe-secret-key

# Supabase send_email hook HMAC secret - keep different from staging.
# Rotate both here AND via setup-fly-secrets.sh (which syncs Supabase automatically).
SEND_EMAIL_HOOK_SECRET_PROD=

# Resend email delivery
RESEND_API_KEY_PROD=
RESEND_WEBHOOK_SECRET_PROD=

# PII encryption key - keep different from staging for isolation.
CONTACT_DATA_ENCRYPTION_KEY_PROD=

# Cloudflare Turnstile (production site key from dash.cloudflare.com > Turnstile)
CLOUDFLARE_TURNSTILE_SITE_KEY_PROD=
CLOUDFLARE_TURNSTILE_SECRET_KEY_PROD=
