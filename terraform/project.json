{
	"name": "terraform",
	"$schema": "../node_modules/nx/schemas/project-schema.json",
	"root": "terraform",
	"sourceRoot": "terraform",
	"projectType": "application",
	"tags": ["scope:infra"],
	"targets": {
		"plan-infrastructure": {
			"dependsOn": [
				{
					"projects": ["vectreal-optimize-textures-function"],
					"target": "build"
				}
			],
			"executor": "nx:run-commands",
			"options": {
				"command": "terraform -chdir=terraform init -input=false && terraform -chdir=terraform validate && terraform -chdir=terraform plan"
			}
		},
		"apply-infrastructure-auto-approve": {
			"dependsOn": [
				{
					"projects": ["vectreal-optimize-textures-function"],
					"target": "build"
				}
			],
			"executor": "nx:run-commands",
			"options": {
				"command": "terraform -chdir=terraform init -input=false && terraform -chdir=terraform validate && terraform -chdir=terraform apply -auto-approve"
			}
		},
		"apply-infrastructure": {
			"dependsOn": [
				{
					"projects": ["vectreal-optimize-textures-function"],
					"target": "build"
				}
			],
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/apply-infrastructure.sh"
			}
		},
		"bootstrap-local-gcs": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/bootstrap-local-gcs.sh"
			}
		},
		"setup-github-secrets": {
			"executor": "nx:run-commands",
			"options": {
				"cwd": "terraform",
				"command": "./scripts/setup-github-secrets.sh"
			}
		}
	}
}
