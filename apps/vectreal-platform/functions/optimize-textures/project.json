{
	"name": "vectreal-optimize-textures-function",
	"$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/vectreal-platform/functions/optimize-textures/src",
	"projectType": "application",
	"tags": [],
	"targets": {
		"typecheck": {
			"executor": "nx:run-commands",
			"outputs": [],
			"options": {
				"command": "pnpm exec tsc -p apps/vectreal-platform/functions/optimize-textures/tsconfig.json --noEmit"
			}
		},
		"build": {
			"dependsOn": ["typecheck"],
			"executor": "nx:run-commands",
			"outputs": [
				"{workspaceRoot}/build/apps/vectreal-platform/functions/optimize-textures"
			],
			"options": {
				"commands": [
					"rm -rf apps/vectreal-platform/functions/optimize-textures/dist",
					"pnpm exec tsc -p apps/vectreal-platform/functions/optimize-textures/tsconfig.json",
					"rm -rf build/apps/vectreal-platform/functions/optimize-textures",
					"mkdir -p build/apps/vectreal-platform/functions/optimize-textures",
					"rsync -a apps/vectreal-platform/functions/optimize-textures/dist/ build/apps/vectreal-platform/functions/optimize-textures/",
					"cp apps/vectreal-platform/functions/optimize-textures/package.json build/apps/vectreal-platform/functions/optimize-textures/package.json"
				],
				"parallel": false
			}
		}
	}
}