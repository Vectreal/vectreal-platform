# =============================================================================
# VECTREAL PLATFORM - DEVELOPMENT + DEPLOYMENT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.development and configure your values.
# DO NOT commit .env.development to version control.

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
NODE_ENV=development
COMPOSE_PROJECT_NAME=vectreal-platform

# Development Server Ports
VITE_DEV_PORT=4200
PROD_PORT=3001
VECTREAL_URL=http://localhost:${VITE_DEV_PORT}
APPLICATION_URL=http://localhost:${VITE_DEV_PORT}

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Local Supabase instance ports
SUPABASE_API_PORT=54321
SUPABASE_DB_PORT=54322
SUPABASE_STUDIO_PORT=54323
SUPABASE_INBUCKET_PORT=54324
SUPABASE_ANALYTICS_PORT=54327

# Supabase Authentication (generate your own secure tokens)
SUPABASE_DB_PASSWORD=postgres
# SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Supabase Keys (default development keys - replace in production)
SUPABASE_URL=http://localhost:${SUPABASE_API_PORT}
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Supabase CLI Access Token (for remote operations)
# SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (Optional - configure if using OAuth)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key


# -----------------------------------------------------------------------------
# AI/ML SERVICES (Optional)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:${SUPABASE_DB_PASSWORD}@localhost:${SUPABASE_DB_PORT}/postgres
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=20
DB_MAX_LIFETIME=1800

# -----------------------------------------------------------------------------
# GOOGLE CLOUD STORAGE (required for upload/download flows)
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_STORAGE_CREDENTIALS_DIR=credentials
GOOGLE_CLOUD_STORAGE_CREDENTIALS_FILE=
# Legacy fallback (optional): GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_STORAGE_PRIVATE_BUCKET=

# -----------------------------------------------------------------------------
# DEPLOYMENT/CI SECRETS (used by Terraform helper scripts)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=vectreal-platform

# GitHub App release identity (used by package release workflow)
RELEASE_APP_ID=
# Preferred: relative path from repo root to the App private key PEM file
RELEASE_APP_PRIVATE_KEY_FILE=credentials/github-release-app.private-key.pem

SUPABASE_PROJECT_REF_PROD=
SUPABASE_DB_PASSWORD_PROD=
DATABASE_URL_PROD=postgresql://postgres:${SUPABASE_DB_PASSWORD_PROD}@db.${SUPABASE_PROJECT_REF_PROD}.supabase.co:5432/postgres
SUPABASE_URL_PROD=https://${SUPABASE_PROJECT_REF_PROD}.supabase.co
SUPABASE_KEY_PROD=eyJhbGc...your-production-key
GOOGLE_CLOUD_STORAGE_PRIVATE_BUCKET_PROD=vectreal-private-bucket
APPLICATION_URL_PROD=https://vectreal.com
CSRF_SECRET_PROD=replace-with-a-long-random-production-secret
STRIPE_SECRET_KEY_PROD=sk_live_your-production-stripe-secret-key
CONTACT_DATA_ENCRYPTION_KEY_PROD=
RESEND_API_KEY_PROD=
RESEND_WEBHOOK_SECRET_PROD=
CONTACT_INBOX_EMAIL_PROD=info@vectreal.com
CONTACT_FROM_EMAIL_PROD="Vectreal <info@vectreal.com>"

SUPABASE_PROJECT_REF_STAGING=
SUPABASE_DB_PASSWORD_STAGING=
DATABASE_URL_STAGING=postgresql://postgres:${SUPABASE_DB_PASSWORD_STAGING}@db.${SUPABASE_PROJECT_REF_STAGING}.supabase.co:5432/postgres
SUPABASE_URL_STAGING=https://${SUPABASE_PROJECT_REF_STAGING}.supabase.co
SUPABASE_KEY_STAGING=eyJhbGc...your-staging-key
GOOGLE_CLOUD_STORAGE_PRIVATE_BUCKET_STAGING=vectreal-private-bucket-staging
APPLICATION_URL_STAGING=https://staging.vectreal.com
CSRF_SECRET_STAGING=replace-with-a-long-random-staging-secret
STRIPE_SECRET_KEY_STAGING=sk_test_your-staging-stripe-secret-key
CONTACT_DATA_ENCRYPTION_KEY_STAGING=
RESEND_API_KEY_STAGING=
RESEND_WEBHOOK_SECRET_STAGING=
CONTACT_INBOX_EMAIL_STAGING=info@vectreal.com
CONTACT_FROM_EMAIL_STAGING="Vectreal <info@vectreal.com>"

# -----------------------------------------------------------------------------
# ANALYTICS (PostHog)
# -----------------------------------------------------------------------------
# Get these from your PostHog project settings: https://app.posthog.com/settings
VITE_PUBLIC_POSTHOG_TOKEN=phc_your-posthog-project-api-key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# CONTACT EMAIL DELIVERY (optional in local dev, required in production)
# -----------------------------------------------------------------------------
# Resend API key used by /contact route action
RESEND_API_KEY=
# Resend webhook secret used by /api/contact/webhook signature verification
RESEND_WEBHOOK_SECRET=
# 32-byte base64 key or passphrase used to encrypt contact form PII before DB persistence
CONTACT_DATA_ENCRYPTION_KEY=
# Inbox where contact form messages are forwarded
CONTACT_INBOX_EMAIL=info@vectreal.com
# Verified sender configured in your email provider
CONTACT_FROM_EMAIL="Vectreal <info@vectreal.com>"

# -----------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# -----------------------------------------------------------------------------
VITE_DEV_TOOLS=true
VITE_MOCK_API=false
VITE_DEBUG_MODE=true
VITE_HMR_PORT=${VITE_DEV_PORT}
VITE_HMR_HOST=localhost
